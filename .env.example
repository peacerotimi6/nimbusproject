# Azure Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Azure Subscription ID
# Get your subscription ID with: az account show --query id -o tsv
ARM_SUBSCRIPTION_ID=your-subscription-id-here

# Optional: Azure Tenant ID (if using service principal)
# ARM_TENANT_ID=your-tenant-id-here

# Optional: Azure Client ID (if using service principal)
# ARM_CLIENT_ID=your-client-id-here

# Optional: Azure Client Secret (if using service principal)
# ARM_CLIENT_SECRET=your-client-secret-here

